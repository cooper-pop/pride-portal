{
  "rewrites": [
    {
      "source": "/js/:file*",
      "destination": "/public/js/:file*"
    },
    {
      "source": "/css/:file*",
      "destination": "/public/css/:file*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/public/index.html"
    }
  ],
  "functions": {
    "api/extract.js": {
      "maxDuration": 60
    },
    "api/parts.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/ai.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/manuals.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/troubleshoot.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/flavor.js": {
      "maxDuration": 30
    },
    "api/bids.js": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    }
  ]
}
