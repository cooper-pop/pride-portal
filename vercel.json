{
  "rewrites": [
    {
      "source": "/js/:file*",
      "destination": "/public/js/:file*"
    },
    {
      "source": "/css/:file*",
      "destination": "/public/css/:file*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/public/index.html"
    }
  ],
  "functions": {
    "api/extract.js": {
      "maxDuration": 60
    },
    "api/parts.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/ai.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/manuals.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/troubleshoot.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/flavor.js": {
      "maxDuration": 30
    },
    "api/bids.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/contracts.js": {
      "maxDuration": 120,
      "memory": 1024,
      "includeFiles": "_contract_seed_text.txt"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://api.anthropic.com https://api.cloudinary.com https://res.cloudinary.com https://cdn.jsdelivr.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    }
  ]
}
