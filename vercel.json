{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/js/:file",
      "destination": "/public/js/:file"
    },
    {
      "source": "/css/:file",
      "destination": "/public/css/:file"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/public/index.html"
    }
  ],
  "functions": {
    "api/extract.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    }
  ]
}